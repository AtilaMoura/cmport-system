              },
              "taskNotification":{
                  "checkIn": 1,
                  "checkout": 2,
                  "rescheduling": 3,
                  "travelStart": 0,
                  "researchAnswer": 1,
                  "delay": 2,
                  "taskDelete": 3
              }
            }

    + Schema

