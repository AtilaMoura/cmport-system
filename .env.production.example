# ── Banco de Dados ────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=cmport_gerenciamento
DB_USER=cmport
DB_PASSWORD=TROQUE_AQUI_SENHA_DB
DB_ROOT_PASSWORD=TROQUE_AQUI_ROOT_PASSWORD

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Gere uma chave forte: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_AQUI_CHAVE_JWT_LONGA
JWT_SECRET=TROQUE_AQUI_CHAVE_JWT_LONGA

# ── Auvo ──────────────────────────────────────────────────────────────────────
AUVO_API_KEY=TROQUE_AQUI
AUVO_API_TOKEN=TROQUE_AQUI

# ── Banco Inter ───────────────────────────────────────────────────────────────
INTER_ENV=production
INTER_CLIENT_ID=TROQUE_AQUI
INTER_CLIENT_SECRET=TROQUE_AQUI
INTER_CONTA_CORRENTE=TROQUE_AQUI
INTER_CERT_PATH=app/auth/

# ── App ───────────────────────────────────────────────────────────────────────
ENV=production

# ── Storage (MinIO) ───────────────────────────────────────────────────────────
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=TROQUE_AQUI_OU_USE_minioadmin
STORAGE_SECRET_KEY=TROQUE_AQUI_OU_USE_minioadmin
MINIO_ROOT_USER=TROQUE_AQUI_OU_USE_minioadmin
MINIO_ROOT_PASSWORD=TROQUE_AQUI_OU_USE_minioadmin
STORAGE_BUCKET=cmport-nfe
STORAGE_REGION=us-east-1
